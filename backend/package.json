{
    "name": "media-mtx-sync",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "start": "nest start",
        "start:dev": "nest start --watch",
        "dev": "nest start --watch",
        "build": "nest build",
        "barrels:generate": "node -e \"console.error('Automatic barrel generation is disabled in Phase 1. Maintain curated module-root exports manually.'); process.exit(1)\"",
        "barrels:watch": "node -e \"console.error('Automatic barrel generation watch is disabled in Phase 1. Maintain curated module-root exports manually.'); process.exit(1)\"",
        "imports:barrelize": "node -e \"console.error('Automatic barrel import rewriting is disabled in Phase 1. Use explicit imports instead.'); process.exit(1)\"",
        "imports:sync": "node -e \"console.error('Automatic barrel sync is disabled in Phase 1. Use curated exports and explicit imports instead.'); process.exit(1)\"",
        "imports:watch": "node -e \"console.error('Automatic barrel import watch is disabled in Phase 1. Use explicit imports instead.'); process.exit(1)\"",
        "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "typecheck": "tsc --noEmit",
        "verify": "npm run typecheck && npm run lint && npm run build && npm test -- --forceExit"
    },
    "dependencies": {
        "@nestjs/axios": "^2.0.0",
        "@nestjs/common": "^9.0.0",
        "@nestjs/core": "^9.0.0",
        "@nestjs/event-emitter": "^1.1.0",
        "@nestjs/mapped-types": "^1.2.2",
        "@nestjs/mongoose": "^9.0.0",
        "@nestjs/platform-express": "^9.0.0",
        "@nestjs/platform-socket.io": "^9.0.0",
        "@nestjs/schedule": "^2.0.0",
        "@nestjs/swagger": "^6.3.0",
        "@nestjs/websockets": "^9.0.0",
        "axios": "^1.5.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "dotenv": "^16.0.0",
        "mongoose": "^7.0.0",
        "rxjs": "^7.8.0",
        "socket.io": "^4.8.3",
        "swagger-ui-express": "^4.6.3"
    },
    "devDependencies": {
        "@typescript-eslint/parser": "^6.21.0",
        "@nestjs/cli": "^9.0.0",
        "@nestjs/testing": "^9.0.0",
        "@types/express": "^4.17.0",
        "@types/jest": "^29.0.0",
        "@types/node": "^20.0.0",
        "@types/supertest": "^2.0.0",
        "eslint": "^8.0.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-import-resolver-typescript": "^3.10.1",
        "eslint-plugin-import": "^2.30.0",
        "eslint-plugin-jsdoc": "^39.0.0",
        "eslint-plugin-perfectionist": "^3.9.1",
        "eslint-plugin-prettier": "^5.0.0",
        "barrelsby": "^2.8.1",
        "chokidar-cli": "^3.0.0",
        "concurrently": "^9.1.2",
        "jest": "^29.0.0",
        "prettier": "^3.0.0",
        "supertest": "^6.0.0",
        "ts-morph": "^25.0.1",
        "ts-jest": "^29.0.0",
        "ts-loader": "^9.0.0",
        "ts-node": "^10.0.0",
        "typescript": "^5.0.0"
    }
}
