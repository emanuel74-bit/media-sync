{
    "root": true,
    "env": {
        "node": true,
        "es2020": true,
        "jest": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": ["prettier", "perfectionist", "import"],
    "extends": ["plugin:prettier/recommended"],
    "rules": {
        "no-unused-vars": "off",
        "no-restricted-imports": [
            "error",
            {
                "patterns": [
                    {
                        "group": ["./*/*", "../*/*", "@/*/*"],
                        "message": "Use the folder barrel import (index.ts) instead of deep file imports."
                    }
                ]
            }
        ],
        "import/no-useless-path-segments": [
            "error",
            {
                "noUselessIndex": true
            }
        ],
        "perfectionist/sort-imports": [
            "error",
            {
                "type": "line-length",
                "order": "asc",
                "newlinesBetween": "always",
                "groups": [
                    "type",
                    "builtin",
                    "external",
                    ["internal-type", "internal"],
                    ["parent-type", "sibling-type", "index-type"],
                    ["parent", "sibling", "index"],
                    "object",
                    "unknown"
                ],
                "internalPattern": ["@/**"]
            }
        ],
        "perfectionist/sort-exports": [
            "error",
            {
                "type": "line-length",
                "order": "asc"
            }
        ],
        "perfectionist/sort-named-exports": [
            "error",
            {
                "type": "line-length",
                "order": "asc"
            }
        ]
    }
}
